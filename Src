package com.autocrystal;

import net.minecraft.block.Blocks;
import net.minecraft.client.MinecraftClient;
import net.minecraft.entity.decoration.EndCrystalEntity;
import net.minecraft.util.Hand;
import net.minecraft.util.hit.BlockHitResult;
import net.minecraft.util.math.BlockPos;
import net.minecraft.util.math.Box;
import net.minecraft.util.math.Direction;
import net.minecraft.util.math.Vec3d;

import java.util.List;

public class AutoCrystalFeature {

    private static final int SEARCH_RADIUS = 3;
    private int tickCounter = 0;

    public void onTick(MinecraftClient client) {
        if (client.player == null || client.world == null || client.interactionManager == null) return;
        if (!client.options.useKey.isPressed()) return;

        tickCounter++;

        popNearbyCrystals(client);

        if (tickCounter % 3 == 0) {
            placeOnNearbyObsidian(client);
        }
    }

    private void popNearbyCrystals(MinecraftClient client) {
        Vec3d playerPos = client.player.getPos();
        Box searchBox = new Box(
                playerPos.x - SEARCH_RADIUS, playerPos.y - SEARCH_RADIUS, playerPos.z - SEARCH_RADIUS,
                playerPos.x + SEARCH_RADIUS, playerPos.y + SEARCH_RADIUS, playerPos.z + SEARCH_RADIUS
        );

        List<EndCrystalEntity> crystals = client.world.getEntitiesByClass(
                EndCrystalEntity.class, searchBox, entity -> true
        );

        for (EndCrystalEntity crystal : crystals) {
            client.player.resetLastAttackedTicks();
            client.interactionManager.attackEntity(client.player, crystal);
            client.player.swingHand(Hand.MAIN_HAND);
        }
    }

    private void placeOnNearbyObsidian(MinecraftClient client) {
        BlockPos playerPos = client.player.getBlockPos();

        for (int x = -SEARCH_RADIUS; x <= SEARCH_RADIUS; x++) {
            for (int z = -SEARCH_RADIUS; z <= SEARCH_RADIUS; z++) {
                for (int y = -1; y <= 1; y++) {
                    BlockPos checkPos = playerPos.add(x, y, z);

                    boolean isValidBase = client.world.getBlockState(checkPos).getBlock() == Blocks.OBSIDIAN
                            || client.world.getBlockState(checkPos).getBlock() == Blocks.BEDROCK;

                    if (!isValidBase) continue;

                    BlockPos placePos = checkPos.up();
                    boolean spaceEmpty = client.world.getBlockState(placePos).isAir()
                            && client.world.getBlockState(placePos.up()).isAir();

                    if (!spaceEmpty) continue;

                    Vec3d hitVec = Vec3d.ofCenter(placePos);
                    BlockHitResult hitResult = new BlockHitResult(hitVec, Direction.UP, checkPos, false);
                    client.interactionManager.interactBlock(client.player, Hand.MAIN_HAND, hitResult);
                    return;
                }
            }
        }
    }
}
